{
  "name": "brighterly-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:generate": "supabase gen types typescript --local > src/lib/supabase/types.ts",
    "supabase:push": "supabase db push",
    "curriculum:sql": "npx ts-node --project scripts/tsconfig.json scripts/curriculum/generate-curriculum-sql.ts",
    "curriculum:questions": "npx ts-node --project scripts/tsconfig.json scripts/curriculum/question-generator.ts",
    "curriculum:info": "npx ts-node --project scripts/tsconfig.json scripts/curriculum/index.ts"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "next": "^15.3.0",
    "@supabase/supabase-js": "^2.49.0",
    "@supabase/ssr": "^0.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.2.0",
    "lucide-react": "^0.475.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "supabase": "^2.0.0"
  }
}
